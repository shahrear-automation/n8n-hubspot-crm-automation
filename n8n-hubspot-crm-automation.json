    {
      "parameters": {
        "jsCode": "const d = $json;\n\n// Try to find contact id from different possible shapes\nconst possibleId =\n  d.id ??\n  d.vid ??\n  d.contactId ??\n  d?.results?.[0]?.id ??\n  d?.data?.results?.[0]?.id ??\n  d?.body?.results?.[0]?.id ??\n  null;\n\nreturn [{\n  ...d,\n  found: Boolean(possibleId),\n  contactId: possibleId\n}];"
      },
