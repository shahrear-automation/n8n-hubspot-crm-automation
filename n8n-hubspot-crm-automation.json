    {
      "parameters": {
        "jsCode": "const j = $json;\nreturn [{\n  ...j,\n  email: j.email ? String(j.email).toLowerCase().trim() : \"\",\n  phone: j.phone ? String(j.phone).replace(/\\s+/g,'').trim() : \"\",\n  website: j.website ? String(j.website).trim() : \"\",\n  city: j.city ? String(j.city).toLowerCase().trim() : \"\",\n  business_name: j.business_name ? String(j.business_name).trim() : \"\"\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -176,
        80
      ],
      "id": "37a8869e-0723-4909-8d8e-ff5717149c5a",
      "name": "Normalize Lead Payload"
    },
    {
      "parameters": {
        "jsCode": "let score = 0;\nif ($json.phone) score += 20;\nif ($json.website) score += 15;\nif ($json.rating >= 4.3) score += 15;\nif ($json.reviews >= 50) score += 15;\nif ($json.city === \"dhaka\") score += 10;\nif ($json.source) score += 5;\n\nlet status = \"NEW\";\nif (score >= 80) status = \"HOT\";\nelse if (score >= 60) status = \"QUALIFIED\";\n\nreturn [{ ...$json, lead_score: score, ai_lead_status: status }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        48,
        80
      ],
      "id": "4daaaead-ad02-43b9-a70c-fee61b02ffbb",
      "name": "Compute Lead Score & Structure"
    },
